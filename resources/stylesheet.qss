/* ==========================================================================
   Assistant Desktop App Design System (Qt Style Sheet - QSS)
   ========================================================================== */

/* --- Default Typography and Base Widgets --- */
* {
    font-family: 'Inter', 'Segoe UI', 'Helvetica Neue', Arial, sans-serif;
    font-size: 13px;
    outline: none;
}

/* --- Theme Selection Selectors --- */

/* 1. DARK THEME STYLING (Default) */
QWidget[theme="dark-theme"] {
    background-color: #090a0f;
    color: #f3f4f6;
}

QWidget[theme="dark-theme"] QWidget#topBar {
    background-color: #0e101a;
    border-bottom: 1px solid rgba(255, 255, 255, 0.07);
}

QWidget[theme="dark-theme"] QLabel#brandTitle {
    color: #ffffff;
}

QWidget[theme="dark-theme"] QWidget#navSection {
    background-color: rgba(0, 0, 0, 0.2);
    border: 1px solid rgba(255, 255, 255, 0.07);
}

QWidget[theme="dark-theme"] QPushButton#btnBack,
QWidget[theme="dark-theme"] QPushButton#btnForward,
QWidget[theme="dark-theme"] QPushButton#btnReload,
QWidget[theme="dark-theme"] QPushButton#btnReset {
    color: #9ca3af;
    background-color: transparent;
}

QWidget[theme="dark-theme"] QPushButton#btnBack:hover,
QWidget[theme="dark-theme"] QPushButton#btnForward:hover,
QWidget[theme="dark-theme"] QPushButton#btnReload:hover,
QWidget[theme="dark-theme"] QPushButton#btnReset:hover {
    color: #ffffff;
    background-color: rgba(255, 255, 255, 0.05);
}

/* 2. LIGHT THEME STYLING */
QWidget[theme="light-theme"] {
    background-color: #f3f4f6;
    color: #111827;
}

QWidget[theme="light-theme"] QWidget#topBar {
    background-color: #ffffff;
    border-bottom: 1px solid rgba(0, 0, 0, 0.08);
}

QWidget[theme="light-theme"] QLabel#brandTitle {
    color: #111827;
}

QWidget[theme="light-theme"] QWidget#navSection {
    background-color: rgba(0, 0, 0, 0.02);
    border: 1px solid rgba(0, 0, 0, 0.08);
}

QWidget[theme="light-theme"] QPushButton#btnBack,
QWidget[theme="light-theme"] QPushButton#btnForward,
QWidget[theme="light-theme"] QPushButton#btnReload,
QWidget[theme="light-theme"] QPushButton#btnReset {
    color: #4b5563;
    background-color: transparent;
}

QWidget[theme="light-theme"] QPushButton#btnBack:hover,
QWidget[theme="light-theme"] QPushButton#btnForward:hover,
QWidget[theme="light-theme"] QPushButton#btnReload:hover,
QWidget[theme="light-theme"] QPushButton#btnReset:hover {
    color: #111827;
    background-color: rgba(0, 0, 0, 0.04);
}

/* --- Common UI Components --- */

/* App Sidebar Panel */
QWidget#topBar {
    min-height: 44px;
    max-height: 44px;
}

/* Brand Section */
QWidget#brandSection {
    background-color: transparent;
}

QLabel#brandTitle {
    font-family: 'Outfit', sans-serif;
    font-size: 20px;
    font-weight: bold;
    letter-spacing: -0.5px;
}

/* Brand Assistant Dropdown Menu Button */
QPushButton#btnAssistantMenu {
    font-family: 'Outfit', sans-serif;
    font-size: 16px;
    font-weight: bold;
    letter-spacing: -0.5px;
    background-color: transparent;
    color: #ffffff;
    border: none;
    padding: 0px 8px 0px 0px;
    margin: 0px;
    min-height: 32px;
    text-align: left;
}

QPushButton#btnAssistantMenu:hover {
    color: #8b5cf6;
}

QPushButton#btnAssistantMenu::menu-indicator {
    image: none;
    width: 0px;
}

QWidget[theme="light-theme"] QPushButton#btnAssistantMenu {
    color: #111827;
}

QWidget[theme="light-theme"] QPushButton#btnAssistantMenu:hover {
    color: #8b5cf6;
}

/* Glassmorphic Dropdown Menu */
QMenu#assistantMenu {
    background-color: #0e101a;
    border: 1px solid rgba(255, 255, 255, 0.08);
    border-radius: 10px;
    padding: 4px 0px;
}

QMenu#assistantMenu::item {
    background-color: transparent;
    padding: 8px 24px;
    color: #9ca3af;
    font-size: 13px;
    font-weight: 500;
}

QMenu#assistantMenu::item:selected {
    background-color: rgba(139, 92, 246, 0.08);
    color: #ffffff;
}

QWidget[theme="light-theme"] QMenu#assistantMenu {
    background-color: #ffffff;
    border: 1px solid rgba(0, 0, 0, 0.08);
}

QWidget[theme="light-theme"] QMenu#assistantMenu::item {
    color: #4b5563;
}

QWidget[theme="light-theme"] QMenu#assistantMenu::item:selected {
    background-color: rgba(139, 92, 246, 0.06);
    color: #8b5cf6;
}

/* Navigation Section */
QWidget#navSection {
    border-radius: 12px;
}

QPushButton#btnBack,
QPushButton#btnForward,
QPushButton#btnReload,
QPushButton#btnReset {
    border: none;
    border-radius: 8px;
    font-weight: bold;
    font-size: 16px;
    min-height: 28px;
    min-width: 28px;
}

QPushButton#btnBack[disabledState="true"],
QPushButton#btnForward[disabledState="true"] {
    color: #4b5563 !important;
}

/* Menu Labels */
QLabel#menuLabel {
    font-family: 'Outfit', sans-serif;
    font-size: 10px;
    font-weight: bold;
    letter-spacing: 1.5px;
    color: #9ca3af;
    padding-left: 6px;
}

/* Switcher Menu Tabs (Gemini, ChatGPT, Grok) */
QPushButton#btnGemini,
QPushButton#btnChatGPT,
QPushButton#btnGrok {
    text-align: left;
    padding: 0px 16px;
    min-height: 48px;
    border-radius: 12px;
    border: 1px solid transparent;
    font-size: 14px;
    font-weight: 500;
    color: #9ca3af;
    background-color: transparent;
}

QPushButton#btnGemini:hover,
QPushButton#btnChatGPT:hover,
QPushButton#btnGrok:hover {
    background-color: rgba(139, 92, 246, 0.03);
    color: #ffffff;
    border-color: rgba(255, 255, 255, 0.05);
}

QWidget[theme="light-theme"] QPushButton#btnGemini:hover,
QWidget[theme="light-theme"] QPushButton#btnChatGPT:hover,
QWidget[theme="light-theme"] QPushButton#btnGrok:hover {
    background-color: rgba(0, 0, 0, 0.02);
    color: #111827;
    border-color: rgba(0, 0, 0, 0.04);
}

/* Gemini Active State */
QPushButton#btnGemini[active="true"] {
    background-color: rgba(139, 92, 246, 0.08);
    color: #ffffff;
    border: 1px solid rgba(139, 92, 246, 0.3);
    font-weight: bold;
}

QWidget[theme="light-theme"] QPushButton#btnGemini[active="true"] {
    background-color: rgba(139, 92, 246, 0.06);
    color: #8b5cf6;
    border: 1px solid rgba(139, 92, 246, 0.2);
}

/* ChatGPT Active State */
QPushButton#btnChatGPT[active="true"] {
    background-color: rgba(16, 185, 129, 0.08);
    color: #ffffff;
    border: 1px solid rgba(16, 185, 129, 0.3);
    font-weight: bold;
}

QWidget[theme="light-theme"] QPushButton#btnChatGPT[active="true"] {
    background-color: rgba(16, 185, 129, 0.06);
    color: #10b981;
    border: 1px solid rgba(16, 185, 129, 0.2);
}

/* Grok Active State */
QPushButton#btnGrok[active="true"] {
    background-color: rgba(228, 228, 227, 0.06);
    color: #ffffff;
    border: 1px solid rgba(228, 228, 227, 0.2);
    font-weight: bold;
}

QWidget[theme="light-theme"] QPushButton#btnGrok[active="true"] {
    background-color: rgba(24, 24, 27, 0.05);
    color: #18181b;
    border: 1px solid rgba(24, 24, 27, 0.15);
}

/* Divider Line */
QFrame#divider {
    max-height: 1px;
    background-color: rgba(255, 255, 255, 0.08);
    border: none;
}

QWidget[theme="light-theme"] QFrame#divider {
    background-color: rgba(0, 0, 0, 0.08);
}

/* Connection Status dot and text */
QWidget#statusDot {
    border-radius: 4px;
    background-color: #10b981;
}

QLabel#statusText {
    font-size: 11px;
    font-weight: 500;
    color: #9ca3af;
}

QWidget[theme="light-theme"] QLabel#statusText {
    color: #4b5563;
}

/* Footer Section Buttons (Redesigned) */
QPushButton#btnSettings,
QPushButton#btnQuit {
    background-color: rgba(0, 0, 0, 0.25);
    color: #9ca3af;
    border: 1px solid rgba(255, 255, 255, 0.07);
    border-radius: 10px;
    min-height: 38px;
    min-width: 38px;
    max-width: 38px;
    padding: 0px;
    font-size: 16px;
    font-weight: bold;
}

QPushButton#btnSettings:hover {
    background-color: rgba(255, 255, 255, 0.05);
    color: #ffffff;
    border-color: rgba(255, 255, 255, 0.15);
}

QPushButton#btnQuit:hover {
    background-color: rgba(239, 68, 68, 0.08);
    color: #f87171;
    border-color: rgba(239, 68, 68, 0.3);
}

QWidget[theme="light-theme"] QPushButton#btnSettings,
QWidget[theme="light-theme"] QPushButton#btnQuit {
    background-color: #ffffff;
    color: #4b5563;
    border: 1px solid rgba(0, 0, 0, 0.08);
}

QWidget[theme="light-theme"] QPushButton#btnSettings:hover {
    background-color: rgba(0, 0, 0, 0.03);
    color: #111827;
    border-color: rgba(0, 0, 0, 0.15);
}

QWidget[theme="light-theme"] QPushButton#btnQuit:hover {
    background-color: rgba(239, 68, 68, 0.05);
    color: #ef4444;
    border-color: rgba(239, 68, 68, 0.2);
}

/* --- Window Control Buttons (Minimize, Maximize, Close) --- */
QPushButton#btnWindowMinimize,
QPushButton#btnWindowMaximize,
QPushButton#btnWindowClose {
    background-color: transparent;
    color: #9ca3af;
    border: none;
    border-radius: 6px;
    min-height: 28px;
    min-width: 28px;
    max-height: 28px;
    max-width: 28px;
    font-family: 'Segoe UI', Arial, sans-serif;
    font-size: 15px;
    font-weight: normal;
}

QPushButton#btnWindowMinimize:hover,
QPushButton#btnWindowMaximize:hover {
    background-color: rgba(255, 255, 255, 0.08);
    color: #ffffff;
}

QPushButton#btnWindowClose:hover {
    background-color: #ef4444;
    color: #ffffff;
}

/* Light Theme window controls */
QWidget[theme="light-theme"] QPushButton#btnWindowMinimize,
QWidget[theme="light-theme"] QPushButton#btnWindowMaximize,
QWidget[theme="light-theme"] QPushButton#btnWindowClose {
    color: #4b5563;
}

QWidget[theme="light-theme"] QPushButton#btnWindowMinimize:hover,
QWidget[theme="light-theme"] QPushButton#btnWindowMaximize:hover {
    background-color: rgba(0, 0, 0, 0.05);
    color: #111827;
}

QWidget[theme="light-theme"] QPushButton#btnWindowClose:hover {
    background-color: #ef4444;
    color: #ffffff;
}

/* Stacked Widget Webview Area */
QStackedWidget#stackedWidget {
    background-color: #000000;
    border: none;
}

/* MessageBox Design Enhancements */
QMessageBox {
    background-color: #0e101a;
    color: #f3f4f6;
    border: 1px solid rgba(255, 255, 255, 0.07);
    border-radius: 14px;
}

QMessageBox QLabel {
    color: #f3f4f6;
    font-size: 13px;
}

QMessageBox QPushButton {
    background-color: rgba(139, 92, 246, 0.15);
    color: #ffffff;
    border: 1px solid rgba(139, 92, 246, 0.3);
    border-radius: 8px;
    padding: 6px 18px;
    min-width: 70px;
    font-weight: bold;
}

QMessageBox QPushButton:hover {
    background-color: rgba(139, 92, 246, 0.3);
    border-color: rgba(139, 92, 246, 0.5);
}

/* --- Redesigned Activity History List View --- */
QListWidget#historyList {
    background-color: transparent;
    border: none;
    padding: 0px;
}

QListWidget#historyList::item {
    background-color: transparent;
    border: 1px solid transparent;
    border-radius: 10px;
    padding: 10px 14px;
    color: #9ca3af;
    margin-bottom: 2px;
}

QListWidget#historyList::item:hover {
    background-color: rgba(255, 255, 255, 0.04);
    color: #ffffff;
}

QListWidget#historyList::item:selected {
    background-color: rgba(139, 92, 246, 0.08);
    color: #ffffff;
    border: 1px solid rgba(139, 92, 246, 0.2);
    font-weight: bold;
}

/* Light Theme overrides for History List */
QWidget[theme="light-theme"] QListWidget#historyList::item {
    color: #4b5563;
}

QWidget[theme="light-theme"] QListWidget#historyList::item:hover {
    background-color: rgba(0, 0, 0, 0.03);
    color: #111827;
}

QWidget[theme="light-theme"] QListWidget#historyList::item:selected {
    background-color: rgba(139, 92, 246, 0.06);
    color: #8b5cf6;
    border: 1px solid rgba(139, 92, 246, 0.15);
}

/* Glassmorphic Scrollbars for History List */
QListWidget#historyList QScrollBar:vertical {
    border: none;
    background: transparent;
    width: 6px;
    margin: 0px;
}

QListWidget#historyList QScrollBar::handle:vertical {
    background: rgba(255, 255, 255, 0.15);
    min-height: 20px;
    border-radius: 3px;
}

QListWidget#historyList QScrollBar::handle:vertical:hover {
    background: rgba(255, 255, 255, 0.25);
}

QListWidget#historyList QScrollBar::add-line:vertical,
QListWidget#historyList QScrollBar::sub-line:vertical {
    height: 0px;
}

/* --- Glassmorphic Dialog Modal Skinning --- */
QDialog#settingsDialog {
    background-color: #0e101a;
    border: 1px solid rgba(255, 255, 255, 0.08);
    border-radius: 16px;
}

QWidget[theme="light-theme"] QDialog#settingsDialog {
    background-color: #ffffff;
    border: 1px solid rgba(0, 0, 0, 0.1);
}

QLabel#settingsTitle {
    font-family: 'Outfit', sans-serif;
    font-size: 16px;
    font-weight: bold;
    letter-spacing: 0.5px;
    color: #ffffff;
    margin-bottom: 12px;
}

QWidget[theme="light-theme"] QLabel#settingsTitle {
    color: #111827;
}

QDialog#settingsDialog QRadioButton {
    font-size: 14px;
    color: #9ca3af;
    padding: 6px 4px;
}

QDialog#settingsDialog QRadioButton:hover {
    color: #ffffff;
}

QWidget[theme="light-theme"] QDialog#settingsDialog QRadioButton {
    color: #4b5563;
}

QWidget[theme="light-theme"] QDialog#settingsDialog QRadioButton:hover {
    color: #111827;
}

/* Dialog Buttons */
QPushButton#btnSettingsSave {
    background-color: rgba(139, 92, 246, 0.15);
    color: #ffffff;
    border: 1px solid rgba(139, 92, 246, 0.3);
    border-radius: 8px;
    padding: 8px 24px;
    font-weight: bold;
    min-height: 34px;
}

QPushButton#btnSettingsSave:hover {
    background-color: rgba(139, 92, 246, 0.3);
    border-color: rgba(139, 92, 246, 0.5);
}

QPushButton#btnSettingsCancel {
    background-color: rgba(255, 255, 255, 0.05);
    color: #9ca3af;
    border: 1px solid rgba(255, 255, 255, 0.08);
    border-radius: 8px;
    padding: 8px 24px;
    min-height: 34px;
}

QPushButton#btnSettingsCancel:hover {
    background-color: rgba(255, 255, 255, 0.1);
    color: #ffffff;
}

QWidget[theme="light-theme"] QPushButton#btnSettingsSave {
    background-color: rgba(139, 92, 246, 0.1);
    color: #8b5cf6;
    border: 1px solid rgba(139, 92, 246, 0.2);
}

QWidget[theme="light-theme"] QPushButton#btnSettingsSave:hover {
    background-color: rgba(139, 92, 246, 0.2);
}

QWidget[theme="light-theme"] QPushButton#btnSettingsCancel {
    background-color: rgba(0, 0, 0, 0.03);
    color: #4b5563;
    border: 1px solid rgba(0, 0, 0, 0.08);
}

QWidget[theme="light-theme"] QPushButton#btnSettingsCancel:hover {
    background-color: rgba(0, 0, 0, 0.06);
    color: #111827;
}
